{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pf-core.io/ontologies/pii-governance-microsoft-native/v2.0.0",
  "title": "PII Governance Ontology - Microsoft Native Web Apps",
  "description": "Ontology for PII protection in web applications using Azure SQL Database Graph, Microsoft Graph API, Presidio, and Azure OpenAI",
  "version": "2.0.0",
  "created": "2026-02-03",
  "author": "PF-Core Security Module",
  "schemaOrgAlignment": 0.85,
  "pfCoreModule": "SECURITY",
  "pfCoreInstances": ["BAIV-SEC", "W4M-RCS", "AIR-GOV"],

  "definitions": {
    "DataResidencyRegion": {
      "@type": "schema:Place",
      "description": "Geographic region for data residency compliance",
      "enum": ["UK", "EU", "US", "GLOBAL"],
      "properties": {
        "regionCode": {
          "type": "string",
          "description": "ISO 3166-1 region code"
        },
        "azureRegion": {
          "type": "string",
          "description": "Azure region identifier",
          "enum": ["uksouth", "ukwest", "northeurope", "westeurope", "eastus", "westus"]
        },
        "dataProtectionLaw": {
          "type": "string",
          "description": "Primary data protection regulation",
          "enum": ["UK-GDPR", "GDPR", "CCPA", "HIPAA"]
        },
        "adequacyDecision": {
          "type": "boolean",
          "description": "Has EU adequacy decision"
        }
      }
    },

    "PIIEntityType": {
      "@type": "schema:DefinedTerm",
      "description": "Type of personally identifiable information",
      "properties": {
        "entityCode": {
          "type": "string",
          "description": "Presidio entity type code"
        },
        "displayName": {
          "type": "string"
        },
        "riskLevel": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
        },
        "ukSpecific": {
          "type": "boolean",
          "description": "Whether this is a UK-specific PII type"
        },
        "presidioBuiltIn": {
          "type": "boolean",
          "description": "Whether Presidio has built-in recognition"
        },
        "regexPattern": {
          "type": "string",
          "description": "Regex pattern for detection"
        },
        "contextKeywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Context words that increase detection confidence"
        }
      },
      "instances": [
        {
          "entityCode": "UK_NINO",
          "displayName": "UK National Insurance Number",
          "riskLevel": "CRITICAL",
          "ukSpecific": true,
          "presidioBuiltIn": false,
          "regexPattern": "[A-CEGHJ-PR-TW-Z]{2}\\s?\\d{2}\\s?\\d{2}\\s?\\d{2}\\s?[A-D]",
          "contextKeywords": ["national insurance", "NI number", "NINO", "HMRC", "tax"]
        },
        {
          "entityCode": "UK_NHS_NUMBER",
          "displayName": "UK NHS Number",
          "riskLevel": "CRITICAL",
          "ukSpecific": true,
          "presidioBuiltIn": false,
          "regexPattern": "\\d{3}\\s?\\d{3}\\s?\\d{4}",
          "contextKeywords": ["NHS", "patient", "medical", "hospital", "GP"]
        },
        {
          "entityCode": "UK_POSTCODE",
          "displayName": "UK Postcode",
          "riskLevel": "MEDIUM",
          "ukSpecific": true,
          "presidioBuiltIn": false,
          "regexPattern": "[A-Z]{1,2}\\d[A-Z\\d]?\\s?\\d[A-Z]{2}",
          "contextKeywords": ["address", "postcode", "postal", "delivery"]
        },
        {
          "entityCode": "UK_DRIVING_LICENCE",
          "displayName": "UK Driving Licence Number",
          "riskLevel": "HIGH",
          "ukSpecific": true,
          "presidioBuiltIn": false,
          "regexPattern": "[A-Z]{5}\\d{6}[A-Z]{2}\\d{2}",
          "contextKeywords": ["driving", "licence", "DVLA", "driver"]
        },
        {
          "entityCode": "UK_BANK_ACCOUNT",
          "displayName": "UK Bank Account (Sort Code + Account)",
          "riskLevel": "CRITICAL",
          "ukSpecific": true,
          "presidioBuiltIn": false,
          "regexPattern": "\\d{2}-\\d{2}-\\d{2}|\\d{8}",
          "contextKeywords": ["bank", "account", "sort code", "payment", "BACS"]
        },
        {
          "entityCode": "PERSON",
          "displayName": "Person Name",
          "riskLevel": "MEDIUM",
          "ukSpecific": false,
          "presidioBuiltIn": true
        },
        {
          "entityCode": "EMAIL_ADDRESS",
          "displayName": "Email Address",
          "riskLevel": "MEDIUM",
          "ukSpecific": false,
          "presidioBuiltIn": true
        },
        {
          "entityCode": "PHONE_NUMBER",
          "displayName": "Phone Number",
          "riskLevel": "MEDIUM",
          "ukSpecific": false,
          "presidioBuiltIn": true
        },
        {
          "entityCode": "CREDIT_CARD",
          "displayName": "Credit Card Number",
          "riskLevel": "CRITICAL",
          "ukSpecific": false,
          "presidioBuiltIn": true
        },
        {
          "entityCode": "IBAN_CODE",
          "displayName": "IBAN",
          "riskLevel": "CRITICAL",
          "ukSpecific": false,
          "presidioBuiltIn": true
        }
      ]
    },

    "AnonymizationOperator": {
      "@type": "schema:Action",
      "description": "Presidio anonymization operator",
      "properties": {
        "operatorName": {
          "type": "string",
          "enum": ["replace", "redact", "mask", "hash", "encrypt"]
        },
        "isReversible": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "useCase": {
          "type": "string"
        }
      },
      "instances": [
        {
          "operatorName": "replace",
          "isReversible": false,
          "description": "Replace PII with placeholder text",
          "useCase": "General anonymization for AI processing"
        },
        {
          "operatorName": "mask",
          "isReversible": false,
          "description": "Mask characters with asterisks",
          "useCase": "Display partial information (e.g., email, phone)"
        },
        {
          "operatorName": "hash",
          "isReversible": false,
          "description": "One-way cryptographic hash",
          "useCase": "Audit logging, deduplication"
        },
        {
          "operatorName": "encrypt",
          "isReversible": true,
          "description": "AES encryption with key",
          "useCase": "Temporary processing requiring restoration"
        },
        {
          "operatorName": "redact",
          "isReversible": false,
          "description": "Remove PII entirely",
          "useCase": "Training data preparation"
        }
      ]
    },

    "AzureSQLGraphNode": {
      "@type": "schema:Thing",
      "description": "Node table in Azure SQL Database Graph",
      "properties": {
        "tableName": {
          "type": "string"
        },
        "nodeType": {
          "type": "string",
          "enum": ["Organisation", "Person", "Document", "AIInteraction", "Agent", "PIIAuditLog"]
        },
        "hasPIIColumns": {
          "type": "boolean"
        },
        "encryptionType": {
          "type": "string",
          "enum": ["NONE", "ALWAYS_ENCRYPTED_DETERMINISTIC", "ALWAYS_ENCRYPTED_RANDOMIZED", "HASH_ONLY"]
        },
        "rlsEnabled": {
          "type": "boolean",
          "description": "Row-Level Security enabled"
        }
      }
    },

    "AzureSQLGraphEdge": {
      "@type": "schema:Action",
      "description": "Edge table representing relationship in Azure SQL Database Graph",
      "properties": {
        "tableName": {
          "type": "string"
        },
        "fromNode": {
          "type": "string"
        },
        "toNode": {
          "type": "string"
        },
        "relationshipType": {
          "type": "string"
        },
        "hasProperties": {
          "type": "boolean"
        }
      },
      "instances": [
        {
          "tableName": "WorksFor",
          "fromNode": "Person",
          "toNode": "Organisation",
          "relationshipType": "EMPLOYMENT",
          "hasProperties": false
        },
        {
          "tableName": "Authored",
          "fromNode": "Person",
          "toNode": "Document",
          "relationshipType": "AUTHORSHIP",
          "hasProperties": false
        },
        {
          "tableName": "HasAccess",
          "fromNode": "Person",
          "toNode": "Document",
          "relationshipType": "PERMISSION",
          "hasProperties": true
        },
        {
          "tableName": "Initiated",
          "fromNode": "Person",
          "toNode": "AIInteraction",
          "relationshipType": "INITIATED",
          "hasProperties": false
        },
        {
          "tableName": "Referenced",
          "fromNode": "AIInteraction",
          "toNode": "Document",
          "relationshipType": "REFERENCE",
          "hasProperties": true
        },
        {
          "tableName": "PerformedBy",
          "fromNode": "AIInteraction",
          "toNode": "Agent",
          "relationshipType": "EXECUTION",
          "hasProperties": false
        },
        {
          "tableName": "AuditedInteraction",
          "fromNode": "PIIAuditLog",
          "toNode": "AIInteraction",
          "relationshipType": "AUDIT",
          "hasProperties": false
        }
      ]
    },

    "MicrosoftGraphAPIScope": {
      "@type": "schema:DigitalDocument",
      "description": "Microsoft Graph API permission scope",
      "properties": {
        "scopeName": {
          "type": "string"
        },
        "scopeType": {
          "type": "string",
          "enum": ["Delegated", "Application"]
        },
        "consentType": {
          "type": "string",
          "enum": ["User", "Admin"]
        },
        "description": {
          "type": "string"
        },
        "piiExposure": {
          "type": "string",
          "enum": ["NONE", "LOW", "MEDIUM", "HIGH"]
        }
      },
      "instances": [
        {
          "scopeName": "User.Read",
          "scopeType": "Delegated",
          "consentType": "User",
          "description": "Read user profile",
          "piiExposure": "MEDIUM"
        },
        {
          "scopeName": "User.Read.All",
          "scopeType": "Application",
          "consentType": "Admin",
          "description": "Read all users' profiles",
          "piiExposure": "HIGH"
        },
        {
          "scopeName": "Files.Read.All",
          "scopeType": "Application",
          "consentType": "Admin",
          "description": "Read all files",
          "piiExposure": "HIGH"
        },
        {
          "scopeName": "Sites.Read.All",
          "scopeType": "Application",
          "consentType": "Admin",
          "description": "Read SharePoint sites",
          "piiExposure": "HIGH"
        }
      ]
    },

    "AzureOpenAIDeployment": {
      "@type": "schema:SoftwareApplication",
      "description": "Azure OpenAI model deployment",
      "properties": {
        "deploymentName": {
          "type": "string"
        },
        "modelName": {
          "type": "string",
          "enum": ["gpt-4o", "gpt-4o-mini", "gpt-4", "gpt-35-turbo"]
        },
        "deploymentType": {
          "type": "string",
          "enum": ["Regional", "DataZone", "Global"]
        },
        "region": {
          "type": "string"
        },
        "ukDataResidency": {
          "type": "boolean"
        },
        "dataUsedForTraining": {
          "type": "boolean",
          "const": false
        }
      },
      "instances": [
        {
          "deploymentName": "gpt-4o-uksouth",
          "modelName": "gpt-4o",
          "deploymentType": "Regional",
          "region": "uksouth",
          "ukDataResidency": true,
          "dataUsedForTraining": false
        },
        {
          "deploymentName": "gpt-4o-mini-uksouth",
          "modelName": "gpt-4o-mini",
          "deploymentType": "Regional",
          "region": "uksouth",
          "ukDataResidency": true,
          "dataUsedForTraining": false
        }
      ]
    },

    "PIIProtectionAction": {
      "@type": "schema:Action",
      "description": "Action taken when PII is detected",
      "properties": {
        "actionCode": {
          "type": "string",
          "enum": ["ALLOWED", "ANONYMIZED", "BLOCKED", "ALERTED"]
        },
        "triggerCondition": {
          "type": "string"
        },
        "riskLevelsAffected": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
          }
        }
      },
      "instances": [
        {
          "actionCode": "ALLOWED",
          "triggerCondition": "No PII detected",
          "riskLevelsAffected": []
        },
        {
          "actionCode": "ANONYMIZED",
          "triggerCondition": "Low/Medium risk PII detected",
          "riskLevelsAffected": ["LOW", "MEDIUM"]
        },
        {
          "actionCode": "BLOCKED",
          "triggerCondition": "High/Critical risk PII detected",
          "riskLevelsAffected": ["HIGH", "CRITICAL"]
        },
        {
          "actionCode": "ALERTED",
          "triggerCondition": "PII detected in AI output (leakage)",
          "riskLevelsAffected": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
        }
      ]
    },

    "SensitivityLabel": {
      "@type": "schema:DefinedTerm",
      "description": "Microsoft Purview sensitivity label",
      "properties": {
        "labelName": {
          "type": "string"
        },
        "labelId": {
          "type": "string",
          "format": "uuid"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "piiImplication": {
          "type": "string"
        },
        "aiProcessingAllowed": {
          "type": "boolean"
        }
      },
      "instances": [
        {
          "labelName": "Public",
          "priority": 0,
          "piiImplication": "No PII expected",
          "aiProcessingAllowed": true
        },
        {
          "labelName": "Internal",
          "priority": 25,
          "piiImplication": "May contain internal identifiers",
          "aiProcessingAllowed": true
        },
        {
          "labelName": "Confidential",
          "priority": 50,
          "piiImplication": "Likely contains PII",
          "aiProcessingAllowed": true
        },
        {
          "labelName": "Highly-Confidential",
          "priority": 75,
          "piiImplication": "Contains sensitive PII",
          "aiProcessingAllowed": false
        }
      ]
    },

    "MCSBv2AIControl": {
      "@type": "schema:DefinedTerm",
      "description": "Microsoft Cloud Security Benchmark v2 AI control",
      "properties": {
        "controlId": {
          "type": "string",
          "pattern": "^AI-[1-7]$"
        },
        "controlName": {
          "type": "string"
        },
        "piiRelevance": {
          "type": "string"
        },
        "implementationComponent": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "instances": [
        {
          "controlId": "AI-1",
          "controlName": "Ensure Use of Approved Models",
          "piiRelevance": "Prevent PII exposure to unvetted models",
          "implementationComponent": ["Azure OpenAI UK South Regional", "Deployment policies"]
        },
        {
          "controlId": "AI-2",
          "controlName": "Multi-Layered Content Filtering",
          "piiRelevance": "Block PII in inputs/outputs",
          "implementationComponent": ["Presidio", "Azure AI Content Safety"]
        },
        {
          "controlId": "AI-3",
          "controlName": "Safety Meta-Prompts",
          "piiRelevance": "Inject PII protection instructions",
          "implementationComponent": ["System prompt templates"]
        },
        {
          "controlId": "AI-4",
          "controlName": "Least Privilege for Agent Functions",
          "piiRelevance": "Restrict agent access to PII",
          "implementationComponent": ["Azure SQL RLS", "Microsoft Graph permissions"]
        },
        {
          "controlId": "AI-5",
          "controlName": "Human-in-the-Loop",
          "piiRelevance": "Approval gates for PII operations",
          "implementationComponent": ["PII blocking", "Alert pipeline"]
        },
        {
          "controlId": "AI-6",
          "controlName": "Monitoring and Detection",
          "piiRelevance": "Detect PII exposure events",
          "implementationComponent": ["Azure Monitor", "PIIAuditLog", "Sentinel"]
        },
        {
          "controlId": "AI-7",
          "controlName": "Continuous AI Red Teaming",
          "piiRelevance": "Test PII exfiltration vectors",
          "implementationComponent": ["Penetration testing", "Security assessments"]
        }
      ]
    },

    "ComplianceFramework": {
      "@type": "schema:Legislation",
      "description": "Regulatory compliance framework",
      "properties": {
        "frameworkCode": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "jurisdiction": {
          "type": "string"
        },
        "piiArticles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "articleNumber": { "type": "string" },
              "requirement": { "type": "string" }
            }
          }
        }
      },
      "instances": [
        {
          "frameworkCode": "UK-GDPR",
          "fullName": "UK General Data Protection Regulation",
          "jurisdiction": "United Kingdom",
          "piiArticles": [
            { "articleNumber": "5(1)(f)", "requirement": "Integrity and confidentiality" },
            { "articleNumber": "17", "requirement": "Right to erasure" },
            { "articleNumber": "25", "requirement": "Data protection by design" },
            { "articleNumber": "30", "requirement": "Records of processing" },
            { "articleNumber": "32", "requirement": "Security of processing" },
            { "articleNumber": "33", "requirement": "Breach notification" }
          ]
        },
        {
          "frameworkCode": "GDPR",
          "fullName": "EU General Data Protection Regulation",
          "jurisdiction": "European Union",
          "piiArticles": [
            { "articleNumber": "4", "requirement": "Personal data definition" },
            { "articleNumber": "9", "requirement": "Special category data" },
            { "articleNumber": "22", "requirement": "Automated decision-making" }
          ]
        },
        {
          "frameworkCode": "ISO27001",
          "fullName": "ISO/IEC 27001:2022",
          "jurisdiction": "International",
